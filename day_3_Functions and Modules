PROGRAM-2-Write a recursive function for the fibonacci series
def fibonacci(n):
    if n == 0:
        return 0
    elif n == 1:
        return 1
    else:
        return fibonacci(n - 1) + fibonacci(n - 2)

terms = int(input("Enter number of terms: "))

for i in range(terms):
    print(fibonacci(i),end=" ")
